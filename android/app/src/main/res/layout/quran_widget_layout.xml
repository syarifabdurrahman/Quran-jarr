<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="16dp">

    <!-- Header with Icon and Surah Name -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_tag_background"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/jar_gold_accent" />

        <TextView
            android:id="@+id/widget_surah_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Al-Ghashiyah (88:4)"
            android:textColor="@color/jar_gold_accent"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Center Content - Arabic and Translation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header_layout"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_arabic_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="تَصْلَىٰ نَارًا حَامِيَةً"
            android:textColor="@color/jar_text_dark"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/widget_translation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mereka memasuki api (neraka) yang sangat panas."
            android:textColor="@color/jar_text_muted"
            android:textSize="13sp"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end" />
    </LinearLayout>

</RelativeLayout>
